# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build / packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Coverage / test artifacts
.coverage
.coverage.*
htmlcov/

# Runtime logs
logs/
*.log

# Runtime state, fetched assets, generated outputs
cache/
state/
tmp/
output/

# Local environment / secrets
.env
.env.*
*.env
*.local
.python-version

# Playwright / browser leftovers
playwright-report/
test-results/

# Jupyter
.ipynb_checkpoints/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code local state
.claude/

# Raw chat/log archives in ai-context
.ai-context/other-documentation/*.jsonl

# Git merge / patch leftovers
*.orig
*.rej

