<Page
    x:Class="DevDocsDownloader.Desktop.Pages.CachePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <Grid Padding="20" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="Cache" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Inspect source cache usage, refresh individual entries, and clean up stale data without leaving the desktop app." Opacity="0.75" TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border Grid.Row="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="UsageText" FontWeight="SemiBold" />
                    <ProgressBar x:Name="UsageBar" Minimum="0" />
                    <TextBlock x:Name="UsageStatusText" Opacity="0.75" />
                    <ListView x:Name="SourceCardsList" MaxHeight="160" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SourceFilterBox" Header="Source filter" SelectionChanged="OnFilterChanged">
                    <x:String>All sources</x:String>
                </ComboBox>
                <ComboBox x:Name="SortBox" Grid.Column="1" Header="Sort by" SelectionChanged="OnSortChanged">
                    <x:String>Source</x:String>
                    <x:String>Fetched time</x:String>
                    <x:String>Policy</x:String>
                    <x:String>Size</x:String>
                </ComboBox>
                <Button Grid.Column="2" Margin="12,24,0,0" Content="Refresh summary" Click="OnRefresh" />
                <Button Grid.Column="3" Margin="12,24,0,0" Content="Clear selected source" Click="OnClearSource" />
                <Button Grid.Column="4" Margin="12,24,0,0" Content="Clear all cache" Click="OnClearAll" />
            </Grid>

            <Grid Grid.Row="3" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ListView x:Name="CacheList" SelectionChanged="OnSelectionChanged" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RefreshEntryButton" Content="Refresh now" Click="OnRefreshEntry" IsEnabled="False" />
                            <Button x:Name="DeleteEntryButton" Content="Delete entry" Click="OnDeleteEntry" IsEnabled="False" />
                        </StackPanel>
                        <TextBlock x:Name="StatusText" Grid.Row="2" Opacity="0.75" TextWrapping="WrapWholeWords" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="DetailTitleText" FontWeight="SemiBold" Text="Select a cache entry." />
                        <TextBox x:Name="ContentBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
