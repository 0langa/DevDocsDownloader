<Page
    x:Class="DevDocsDownloader.Desktop.Pages.CachePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="6">
            <TextBlock Text="Cache" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Inspect source cache metadata, freshness policy, and stored archive fingerprints." Opacity="0.75" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Name="SortBox" Width="180" SelectionChanged="OnSortChanged">
                            <x:String>Source</x:String>
                            <x:String>Fetched time</x:String>
                            <x:String>Policy</x:String>
                        </ComboBox>
                        <Button Content="Refresh cache" Click="OnRefresh" />
                    </StackPanel>
                    <ListView x:Name="CacheList" SelectionChanged="OnSelectionChanged" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DetailTitleText" FontWeight="SemiBold" Text="Select a cache entry." />
                    <TextBox x:Name="ContentBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
