<Page
    x:Class="DevDocsDownloader.Desktop.Pages.BulkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <Grid Padding="20" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Spacing="6">
                <TextBlock Text="Bulk run" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Search and select languages from the catalog, or download all at once. Active job progress stays live while you inspect other tabs." Opacity="0.75" TextWrapping="WrapWholeWords" />
            </StackPanel>

            <!-- Form + Live progress -->
            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">

                        <!-- Language search + add -->
                        <AutoSuggestBox
                            x:Name="LanguageSearchBox"
                            Header="Add language"
                            PlaceholderText="Search catalog (e.g. python, angular, react)..."
                            TextChanged="OnLanguageSearchTextChanged"
                            SuggestionChosen="OnLanguageSuggestionChosen"
                            QuerySubmitted="OnLanguageQuerySubmitted" />

                        <!-- Selected languages list -->
                        <StackPanel Spacing="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SelectedCountText" Text="No languages selected" VerticalAlignment="Center" Opacity="0.8" />
                                <Button x:Name="ClearLanguagesButton" Grid.Column="1" Content="Clear all" Click="OnClearLanguages" IsEnabled="False" />
                            </Grid>
                            <ListView
                                x:Name="SelectedLanguagesList"
                                MaxHeight="180"
                                SelectionMode="None"
                                Padding="0" />
                        </StackPanel>

                        <!-- Mode / Version filter / Source row -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ModeBox" Header="Mode" SelectionChanged="OnFormChanged">
                                <x:String>important</x:String>
                                <x:String>full</x:String>
                            </ComboBox>
                            <ComboBox x:Name="VersionFilterBox" Grid.Column="1" Header="Versions" SelectionChanged="OnVersionFilterChanged">
                                <x:String>Latest only</x:String>
                                <x:String>All versions</x:String>
                            </ComboBox>
                            <ComboBox x:Name="SourceBox" Grid.Column="2" Header="Preferred source" SelectionChanged="OnFormChanged" />
                        </Grid>

                        <!-- Concurrency row -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ConcurrencyBox" Header="Language concurrency" Text="3" TextChanged="OnFormChanged" />
                            <ComboBox x:Name="PolicyBox" Grid.Column="1" Header="Concurrency policy" SelectionChanged="OnFormChanged">
                                <x:String>static</x:String>
                                <x:String>adaptive</x:String>
                            </ComboBox>
                        </Grid>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="StartBulkButton" Content="Start bulk run" Click="OnStartBulk" />
                            <Button x:Name="DownloadAllButton" Content="Download all" Click="OnDownloadAll" IsEnabled="False" />
                            <Button Content="Cancel active job" Click="OnCancelJob" />
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- Live progress panel -->
                <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Live progress" FontSize="20" FontWeight="SemiBold" />
                        <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" />
                        <TextBlock x:Name="PhaseText" FontWeight="SemiBold" />
                        <TextBlock x:Name="ActivityText" TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="CountsText" Opacity="0.75" />
                        <TextBlock x:Name="WarningsText" Foreground="Goldenrod" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Activity log -->
            <Grid Grid.Row="2" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Recent activity" FontSize="20" FontWeight="SemiBold" />
                <ListView x:Name="EventsList" Grid.Row="1" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
