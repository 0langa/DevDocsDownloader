<Page
    x:Class="DevDocsDownloader.Desktop.Pages.BulkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="12" Padding="16">
            <TextBlock Text="Bulk run" FontSize="20" FontWeight="SemiBold" />
            <TextBox x:Name="LanguagesBox" Header="Languages (comma-separated)" PlaceholderText="python,javascript,rust" />
            <ComboBox x:Name="ModeBox" Header="Mode" SelectedIndex="0">
                <x:String>important</x:String>
                <x:String>full</x:String>
            </ComboBox>
            <TextBox x:Name="ConcurrencyBox" Header="Language concurrency" Text="3" />
            <ComboBox x:Name="PolicyBox" Header="Concurrency policy" SelectedIndex="0">
                <x:String>static</x:String>
                <x:String>adaptive</x:String>
            </ComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Start bulk run" Click="OnStartBulk" />
                <Button Content="Refresh last job" Click="OnRefreshJob" />
            </StackPanel>
            <TextBlock x:Name="JobStatusText" TextWrapping="Wrap" />
            <TextBox x:Name="EventsBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Height="420" />
        </StackPanel>
    </ScrollViewer>
</Page>
