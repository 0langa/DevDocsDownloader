<Page
    x:Class="DevDocsDownloader.Desktop.Pages.RunPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <Grid Padding="20" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Text="Run one language" FontSize="28" FontWeight="SemiBold" />
                <TextBlock x:Name="OutputRootText" Opacity="0.75" TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBox x:Name="LanguageBox" Header="Language" PlaceholderText="python" TextChanged="OnFormChanged" />
                        <ComboBox x:Name="ModeBox" Header="Mode" SelectionChanged="OnFormChanged">
                            <x:String>important</x:String>
                            <x:String>full</x:String>
                        </ComboBox>
                        <ComboBox x:Name="SourceBox" Header="Preferred source" SelectionChanged="OnFormChanged" />
                        <CheckBox x:Name="ValidateOnlyBox" Content="Validate only existing output" Checked="OnFormChanged" Unchecked="OnFormChanged" />
                        <CheckBox x:Name="ForceRefreshBox" Content="Force refresh source cache" Checked="OnFormChanged" Unchecked="OnFormChanged" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="StartRunButton" Content="Start run" Click="OnStartRun" />
                            <Button Content="Cancel active job" Click="OnCancelJob" />
                        </StackPanel>
                        <TextBlock Text="Language lookup uses the merged source catalog. You can pick a language directly from the Languages tab to prefill this form." Opacity="0.7" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Live progress" FontSize="20" FontWeight="SemiBold" />
                        <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" />
                        <TextBlock x:Name="PhaseText" FontWeight="SemiBold" />
                        <TextBlock x:Name="ActivityText" TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="CountsText" Opacity="0.75" />
                        <TextBlock x:Name="WarningsText" Foreground="Goldenrod" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Recent activity" FontSize="20" FontWeight="SemiBold" />
                <ListView x:Name="EventsList" Grid.Row="1" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
