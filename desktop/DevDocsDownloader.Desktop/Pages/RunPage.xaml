<Page
    x:Class="DevDocsDownloader.Desktop.Pages.RunPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="12" Padding="16">
            <TextBlock Text="Run one language" FontSize="20" FontWeight="SemiBold" />
            <TextBox x:Name="LanguageBox" Header="Language" PlaceholderText="python" />
            <ComboBox x:Name="ModeBox" Header="Mode" SelectedIndex="0">
                <x:String>important</x:String>
                <x:String>full</x:String>
            </ComboBox>
            <TextBox x:Name="SourceBox" Header="Source (optional)" PlaceholderText="devdocs, mdn, dash" />
            <CheckBox x:Name="ValidateOnlyBox" Content="Validate only" />
            <CheckBox x:Name="ForceRefreshBox" Content="Force refresh" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Start run" Click="OnStartRun" />
                <Button Content="Refresh last job" Click="OnRefreshJob" />
            </StackPanel>
            <TextBlock Text="Job status" FontWeight="SemiBold" />
            <TextBlock x:Name="JobStatusText" Text="No job started." TextWrapping="Wrap" />
            <TextBlock Text="Event stream" FontWeight="SemiBold" />
            <TextBox x:Name="EventsBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Height="420" />
        </StackPanel>
    </ScrollViewer>
</Page>
