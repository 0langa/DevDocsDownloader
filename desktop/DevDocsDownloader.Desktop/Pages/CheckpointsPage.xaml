<Page
    x:Class="DevDocsDownloader.Desktop.Pages.CheckpointsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="6">
            <TextBlock Text="Checkpoints" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Checkpoint files record restart-safe boundaries for incomplete or failed runs." Opacity="0.75" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <Button Content="Refresh checkpoints" Click="OnList" />
                    <ListView x:Name="CheckpointList" SelectionChanged="OnSelectionChanged" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="UseCheckpointButton" Content="Use in Run" Click="OnUseCheckpoint" IsEnabled="False" />
                        <Button x:Name="DeleteCheckpointButton" Content="Delete checkpoint" Click="OnDelete" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DetailTitleText" FontWeight="SemiBold" Text="Select a checkpoint." />
                    <TextBox x:Name="ContentBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
