<Page
    x:Class="DevDocsDownloader.Desktop.Pages.CheckpointsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="12" Padding="16">
        <TextBlock Text="Checkpoints" FontSize="20" FontWeight="SemiBold" />
        <TextBox x:Name="SlugBox" Header="Checkpoint slug" PlaceholderText="python" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="List checkpoints" Click="OnList" />
            <Button Content="Load checkpoint" Click="OnLoad" />
            <Button Content="Delete checkpoint" Click="OnDelete" />
        </StackPanel>
        <TextBox x:Name="ContentBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Height="520" />
    </StackPanel>
</Page>
