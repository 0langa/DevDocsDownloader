<Page
    x:Class="DevDocsDownloader.Desktop.Pages.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="6">
            <TextBlock Text="Reports" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Inspect the latest run summary, validation output, and stored report history." Opacity="0.75" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <Button Content="Refresh reports" Click="OnRefresh" />
                    <TextBlock x:Name="SummaryText" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="History files" FontWeight="SemiBold" />
                    <ListView x:Name="HistoryList" SelectionChanged="OnHistorySelectionChanged" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="PreviewTitleText" FontWeight="SemiBold" Text="Report preview" />
                    <TextBox x:Name="ContentBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
