<Page
    x:Class="DevDocsDownloader.Desktop.Pages.LanguagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock Text="Languages" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Browse the merged source catalogs, search by language, and send selections directly into single or bulk runs." Opacity="0.75" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="ViewModeBox" Header="View" SelectionChanged="OnFiltersChanged">
                <x:String>Source-first</x:String>
                <x:String>Category-first</x:String>
            </ComboBox>
            <TextBox x:Name="SearchBox" Grid.Column="1" Header="Search" PlaceholderText="Type language, source, version, or slug" TextChanged="OnFiltersChanged" />
            <ComboBox x:Name="SourceFilterBox" Grid.Column="2" Header="Source filter" SelectionChanged="OnFiltersChanged" />
            <Button Grid.Column="3" Margin="0,22,0,0" Content="Refresh catalogs" Click="OnRefresh" />
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <controls:TreeView x:Name="LanguageTree" SelectionChanged="OnTreeSelectionChanged" />
            <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Selection" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="SelectionTitleText" Text="Choose a language version to see details." TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="SelectionSourceText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="SelectionSlugText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="SelectionCategoriesText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="UseInRunButton" Content="Use in Run" Click="OnUseInRun" IsEnabled="False" />
                        <Button x:Name="UseInBulkButton" Content="Add to Bulk" Click="OnUseInBulk" IsEnabled="False" />
                    </StackPanel>
                    <TextBlock x:Name="SummaryText" Margin="0,12,0,0" TextWrapping="WrapWholeWords" Opacity="0.75" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
