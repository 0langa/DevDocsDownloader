<Page
    x:Class="DevDocsDownloader.Desktop.Pages.PresetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="6">
            <TextBlock Text="Presets / Audit" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Presets group related languages for common workflows. Audit checks which entries resolve cleanly before you start a large run." Opacity="0.75" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Preset groups" FontSize="20" FontWeight="SemiBold" />
                    <Button Content="Refresh presets" Click="OnLoadPresets" />
                    <ListView x:Name="PresetList" SelectionChanged="OnPresetSelectionChanged" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="AuditPresetButton" Content="Audit selected preset" Click="OnAuditSelectedPreset" IsEnabled="False" />
                        <Button x:Name="UsePresetButton" Content="Use in Bulk" Click="OnUsePresetInBulk" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="PresetTitleText" FontSize="20" FontWeight="SemiBold" Text="Select a preset." />
                    <TextBlock x:Name="PresetLanguagesText" Grid.Row="1" TextWrapping="WrapWholeWords" />
                    <ListView x:Name="AuditResultsList" Grid.Row="2" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
