<Page
    x:Class="DevDocsDownloader.Desktop.Pages.PresetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="12" Padding="16">
        <TextBlock Text="Presets / Audit" FontSize="20" FontWeight="SemiBold" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Load presets" Click="OnLoadPresets" />
            <Button Content="Audit presets" Click="OnAuditPresets" />
        </StackPanel>
        <TextBox x:Name="ContentBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Height="520" />
    </StackPanel>
</Page>
