<Page
    x:Class="DevDocsDownloader.Desktop.Pages.OutputBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock Text="Output Browser" FontSize="28" FontWeight="SemiBold" />
            <TextBlock x:Name="OutputRootText" Opacity="0.75" TextWrapping="WrapWholeWords" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
            <Button Content="Refresh bundles" Click="OnRefreshBundles" />
            <Button x:Name="RefreshTreeButton" Content="Reload selected bundle" Click="OnReloadTree" IsEnabled="False" />
            <Button Content="Open output folder" Click="OnOpenOutputFolder" />
            <Button x:Name="OpenWebsiteButton" Content="Open as website" Click="OnOpenWebsite" IsEnabled="False" />
            <Button x:Name="DeleteBundleButton" Content="Delete selected bundle" Click="OnDeleteBundle" IsEnabled="False" />
            <Button Content="Prune report history" Click="OnPruneReportHistory" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.75" />
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Text="Favorites" FontWeight="SemiBold" />
                    <ListView x:Name="FavoritesList" SelectionChanged="OnFavoriteSelectionChanged" MaxHeight="140" />
                    <TextBlock Text="Bundles" FontWeight="SemiBold" />
                    <ListView x:Name="BundlesList" SelectionChanged="OnBundleSelectionChanged" />
                </StackPanel>
                <TextBlock x:Name="StorageSummaryText" Grid.Row="1" Opacity="0.75" TextWrapping="WrapWholeWords" />
            </Grid>
            <controls:TreeView x:Name="FilesTree" Grid.Column="1" SelectionChanged="OnTreeSelectionChanged" />
            <Grid Grid.Column="2" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="PreviewPathText" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                    <Button x:Name="FavoriteButton" Content="☆ Favorite" Click="OnToggleFavorite" IsEnabled="False" />
                </StackPanel>
                <TextBlock x:Name="BundleDetailText" Grid.Row="1" Opacity="0.75" TextWrapping="WrapWholeWords" />
                <TextBox x:Name="PreviewBox" Grid.Row="2" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" KeyDown="OnPreviewKeyDown" />
                <StackPanel Grid.Row="3" Spacing="4">
                    <TextBlock Text="Related documents" FontWeight="SemiBold" />
                    <ListView x:Name="RelatedDocsList" SelectionChanged="OnRelatedSelectionChanged" MaxHeight="140" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
