<Page
    x:Class="DevDocsDownloader.Desktop.Pages.OutputBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="12" Padding="16">
        <TextBlock Text="Output Browser" FontSize="20" FontWeight="SemiBold" />
        <TextBox x:Name="LanguageSlugBox" Header="Language slug" PlaceholderText="python" />
        <TextBox x:Name="RelativePathBox" Header="Relative file path" PlaceholderText="python.md" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="List bundles" Click="OnListBundles" />
            <Button Content="Load tree" Click="OnLoadTree" />
            <Button Content="Load file" Click="OnLoadFile" />
        </StackPanel>
        <TextBox x:Name="ContentBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Height="520" />
    </StackPanel>
</Page>
