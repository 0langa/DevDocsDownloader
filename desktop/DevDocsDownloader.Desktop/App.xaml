<Application
    x:Class="DevDocsDownloader.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#155EEF" />
            <x:Double x:Key="ControlContentThemeFontSize">15</x:Double>
            <x:Double x:Key="CaptionTextBlockFontSize">13</x:Double>
            <Thickness x:Key="ControlContentThemePadding">12,8,12,8</Thickness>
        </ResourceDictionary>
    </Application.Resources>
</Application>
