<Window
    x:Class="DevDocsDownloader.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DevDocsDownloader">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="16" Background="#F3F4F6">
            <StackPanel Spacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="DevDocsDownloader" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}" Opacity="0.7" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <ListBox x:Name="NavigationList" SelectionChanged="OnSelectionChanged">
                    <ListBoxItem Content="Dashboard / Run" Tag="RunPage" />
                    <ListBoxItem Content="Bulk" Tag="BulkPage" />
                    <ListBoxItem Content="Languages" Tag="LanguagesPage" />
                    <ListBoxItem Content="Presets / Audit" Tag="PresetsPage" />
                    <ListBoxItem Content="Reports" Tag="ReportsPage" />
                    <ListBoxItem Content="Output Browser" Tag="OutputBrowserPage" />
                    <ListBoxItem Content="Checkpoints" Tag="CheckpointsPage" />
                    <ListBoxItem Content="Cache" Tag="CachePage" />
                    <ListBoxItem Content="Settings / Help" Tag="SettingsPage" />
                </ListBox>
            </StackPanel>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Column="1" />
    </Grid>
</Window>
